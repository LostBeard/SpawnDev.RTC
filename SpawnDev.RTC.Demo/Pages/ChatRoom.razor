@page "/chat"
@page "/chat/{RoomName}"
@using SpawnDev.RTC
@using SpawnDev.RTC.Browser
@using SpawnDev.RTC.Signaling
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@using SpawnDev.BlazorJS.JSObjects.WebRTC
@implements IAsyncDisposable
@inject BlazorJSRuntime JS

<PageTitle>SpawnDev.RTC - Chat Room</PageTitle>

<div class="chat-container">
    @if (!_joined)
    {
        <div class="join-panel">
            <div class="join-card">
                <h2>Join a Room</h2>
                <p class="text-muted">Enter any room name to create or join a chat room. The name is hashed to create a unique swarm ID.</p>
                <div class="input-group mb-3">
                    <input type="text" class="form-control form-control-lg" placeholder="Room name..."
                           @bind="_roomInput" @bind:event="oninput" @onkeydown="HandleKeyDown" autofocus />
                    <button class="btn btn-primary btn-lg" @onclick="JoinRoom" disabled="@string.IsNullOrWhiteSpace(_roomInput)">
                        Join
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(_roomInput))
                {
                    <small class="text-muted">Swarm ID: @ComputeInfoHash(_roomInput)[..16]...</small>
                }
                <div class="mt-3">
                    <label class="text-muted small">Tracker Server</label>
                    <input type="text" class="form-control form-control-sm" @bind="_trackerUrl"
                           style="background: #222; color: #eee; border-color: #444;" />
                    <small class="text-muted">Uses WebTorrent tracker protocol - no server deployment needed</small>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="room-layout">
            <!-- Header -->
            <div class="room-header">
                <div class="room-info">
                    <h5 class="mb-0">@_roomInput</h5>
                    <small class="text-muted">@(_peers.Count + 1) participant@(_peers.Count != 0 ? "s" : "") - @ComputeInfoHash(_roomInput)[..12]...</small>
                </div>
                <div class="room-controls">
                    <button class="btn @(_micMuted ? "btn-danger" : "btn-outline-light") btn-sm me-1" @onclick="ToggleMic" title="@(_micMuted ? "Unmute Mic" : "Mute Mic")">
                        @(_micMuted ? "Mic Off" : "Mic On")
                    </button>
                    <button class="btn @(_camMuted ? "btn-danger" : "btn-outline-light") btn-sm me-1" @onclick="ToggleCam" title="@(_camMuted ? "Enable Camera" : "Disable Camera")">
                        @(_camMuted ? "Cam Off" : "Cam On")
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="LeaveRoom">Leave</button>
                </div>
            </div>

            <!-- Main content: video grid + chat -->
            <div class="room-body">
                <!-- Video grid -->
                <div class="video-grid" id="video-grid">
                    <!-- Local video -->
                    <div class="video-tile">
                        <video @ref="_localVideoRef" autoplay muted playsinline></video>
                        <div class="video-label">You</div>
                    </div>
                    <!-- Remote videos -->
                    @foreach (var peer in _peers.Values)
                    {
                        <div class="video-tile">
                            <video @ref="peer.VideoRef" autoplay playsinline></video>
                            <div class="video-label">@peer.PeerId[..6]</div>
                        </div>
                    }
                </div>

                <!-- Chat panel -->
                <div class="chat-panel">
                    <div class="chat-messages" @ref="_chatMessagesRef">
                        @foreach (var msg in _messages)
                        {
                            <div class="chat-msg @(msg.IsLocal ? "chat-msg-local" : "")">
                                <span class="chat-sender">@msg.Sender</span>
                                <span class="chat-text">@msg.Text</span>
                            </div>
                        }
                    </div>
                    <div class="chat-input">
                        <input type="text" class="form-control" placeholder="Type a message..."
                               @bind="_chatInput" @bind:event="oninput" @onkeydown="HandleChatKeyDown" />
                        <button class="btn btn-primary btn-sm" @onclick="SendChat" disabled="@string.IsNullOrWhiteSpace(_chatInput)">Send</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .chat-container {
        height: calc(100vh - 60px);
        display: flex;
        flex-direction: column;
    }

    .join-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
    }

    .join-card {
        max-width: 500px;
        width: 100%;
        padding: 2rem;
        background: #1e1e2e;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .join-card h2 {
        color: #e0e0e0;
        margin-bottom: 0.5rem;
    }

    .room-layout {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .room-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 1rem;
        background: #1e1e2e;
        border-bottom: 1px solid #333;
    }

    .room-header h5 { color: #e0e0e0; }

    .room-body {
        display: flex;
        flex: 1;
        overflow: hidden;
    }

    .video-grid {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 8px;
        padding: 8px;
        overflow-y: auto;
        background: #111;
    }

    .video-tile {
        position: relative;
        background: #222;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 16/9;
    }

    .video-tile video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .video-label {
        position: absolute;
        bottom: 8px;
        left: 8px;
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.8rem;
    }

    .chat-panel {
        width: 320px;
        display: flex;
        flex-direction: column;
        border-left: 1px solid #333;
        background: #1a1a2a;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
    }

    .chat-msg {
        margin-bottom: 0.3rem;
        font-size: 0.9rem;
    }

    .chat-sender {
        font-weight: bold;
        color: #7aa2f7;
        margin-right: 0.3rem;
    }

    .chat-msg-local .chat-sender {
        color: #9ece6a;
    }

    .chat-text {
        color: #c0caf5;
    }

    .chat-input {
        display: flex;
        padding: 0.5rem;
        gap: 0.3rem;
        border-top: 1px solid #333;
    }

    .chat-input .form-control {
        background: #222;
        border-color: #444;
        color: #e0e0e0;
    }
</style>

@code {
    [Parameter] public string? RoomName { get; set; }

    // Query-param test hooks - let an iframe/child-window drive the page without human interaction
    // so we can write automated round-trip tests for the actual Blazor component wiring
    // (not just the library layer). See ChatRoomTests.
    [SupplyParameterFromQuery(Name = "room")] public string? RoomFromQuery { get; set; }
    [SupplyParameterFromQuery(Name = "tracker")] public string? TrackerOverride { get; set; }
    [SupplyParameterFromQuery(Name = "noMedia")] public bool NoMedia { get; set; }
    [SupplyParameterFromQuery(Name = "autoJoin")] public bool AutoJoin { get; set; }
    [SupplyParameterFromQuery(Name = "autoSend")] public string? AutoSend { get; set; }
    [SupplyParameterFromQuery(Name = "autoReply")] public string? AutoReply { get; set; }
    [SupplyParameterFromQuery(Name = "testId")] public string? TestId { get; set; }

    private ElementReference _localVideoRef;
    private ElementReference _chatMessagesRef;
    private string _roomInput = "";
    private string _chatInput = "";
    private string _trackerUrl = "wss://tracker.openwebtorrent.com";
    private bool _joined;
    private bool _micMuted;
    private bool _camMuted;
    private TrackerSignalingClient? _tracker;
    private RtcPeerConnectionRoomHandler? _handler;
    private RoomKey _roomKey;
    private MediaStream? _localStream;
    private readonly Dictionary<string, PeerState> _peers = new();
    private readonly List<ChatMessage> _messages = new();
    private readonly Dictionary<IRTCPeerConnection, MediaStreamTrack> _pendingVideoTracks = new();
    private bool _autoSent;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(RoomName)) _roomInput = RoomName;
        if (!string.IsNullOrEmpty(RoomFromQuery)) _roomInput = RoomFromQuery;
        if (!string.IsNullOrEmpty(TrackerOverride)) _trackerUrl = TrackerOverride;
        if (!string.IsNullOrEmpty(TestId))
        {
            // Test liveness ping - if this writes, the host loaded AND ChatRoom.OnInitialized ran
            // AND SupplyParameterFromQuery picked up the testId.
            PublishToHarness($"chatRoomAlive_{TestId}", DateTime.UtcNow.Ticks);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AutoJoin && !_joined && !string.IsNullOrWhiteSpace(_roomInput))
        {
            await JoinRoom();
        }
    }

    // Writes value onto the test harness window (the popup's opener OR the iframe's parent).
    // Popups: window.opener is the test page; window.parent is the popup itself.
    // Iframes: window.opener is null; window.parent is the test page.
    // Writing to both covers both hosting modes; the failing one is a harmless no-op.
    private void PublishToHarness(string key, object? value)
    {
        try { JS.Set($"opener.{key}", value!); } catch { }
        try { JS.Set($"parent.{key}", value!); } catch { }
    }

    // Exposes component state to window.chatRoomState so parent/opener pages (tests) can
    // observe the real wiring end-to-end: peer count, open-channel count, incoming messages.
    private void PublishTestState()
    {
        try
        {
            var openChannels = _peers.Values.Count(p => p.ChatChannel?.ReadyState == "open");
            var state = new
            {
                joined = _joined,
                peerCount = _peers.Count,
                openChannels,
                lastIncoming = _messages.Where(m => !m.IsLocal && m.Sender != "System" && m.Sender != "Error").Select(m => m.Text).LastOrDefault(),
                incomingCount = _messages.Count(m => !m.IsLocal && m.Sender != "System" && m.Sender != "Error"),
                messages = _messages.Select(m => new { m.Sender, m.Text, m.IsLocal }).ToList()
            };
            JS.Set("chatRoomState", state);
            // Also publish to the parent window so an iframe-embedded instance is observable
            // from the outer test page. When not in an iframe, window.parent === window, so
            // this is a harmless duplicate write.
            if (!string.IsNullOrEmpty(TestId))
            {
                PublishToHarness($"chatRoomState_{TestId}", state);
            }
        }
        catch { /* window may not be available during teardown */ }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_roomInput))
            _ = JoinRoom();
    }

    private void HandleChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_chatInput))
            SendChat();
    }

    private async Task JoinRoom()
    {
        if (string.IsNullOrWhiteSpace(_roomInput)) return;

        _joined = true;
        StateHasChanged();
        PublishTestState();
        if (!string.IsNullOrEmpty(TestId))
        {
            PublishToHarness($"chatRoomJoinStart_{TestId}", DateTime.UtcNow.Ticks);
        }

        try
        {
            // Skip camera/mic if the caller opted out (tests, signaling-only use)
            if (!NoMedia)
            {
                using var navigator = JS.Get<Navigator>("navigator");
                using var mediaDevices = navigator.MediaDevices;
                _localStream = await mediaDevices.GetUserMedia(new { audio = true, video = true });

                // Attach local camera to video element
                await Task.Delay(100); // Let Blazor render the video element
                using var localVideo = new HTMLVideoElement(_localVideoRef);
                localVideo.SrcObject = _localStream;
            }

            // Connect to tracker (WebTorrent protocol - serverless signaling)
            var config = new RTCPeerConnectionConfig
            {
                IceServers = new[] { new RTCIceServerConfig { Urls = new[] { "stun:stun.l.google.com:19302" } } }
            };

            _roomKey = RoomKey.FromString(_roomInput);
            _handler = new RtcPeerConnectionRoomHandler(config);

            _handler.OnPeerConnectionCreated = async (pc, peerId) =>
            {
                if (pc is BrowserRTCPeerConnection browserPc)
                {
                    // Wire OnTrack BEFORE any SDP exchange - OnTrack fires during
                    // SetRemoteDescription, so it must be wired before that happens
                    browserPc.NativeConnection.OnTrack += trackEvent =>
                    {
                        if (trackEvent.Track.Kind == "video")
                        {
                            // Store track - we'll attach it to video element when peer is in _peers
                            _pendingVideoTracks[pc] = trackEvent.Track;
                            InvokeAsync(() => AttachPendingVideoTracks());
                        }
                    };

                    // Add local tracks to the connection
                    if (_localStream != null)
                    {
                        foreach (var track in _localStream.GetTracks())
                        {
                            browserPc.NativeConnection.AddTrack(track, _localStream);
                        }
                    }
                }

                await Task.CompletedTask;
            };

            _handler.OnPeerConnection += (pc, peerId) =>
            {
                Console.WriteLine($"[ChatRoom] OnPeerConnection peerId={peerId[..Math.Min(8, peerId.Length)]}");
                InvokeAsync(() =>
                {
                    // Merge into existing PeerState if OnDataChannel already created one for this peer.
                    if (!_peers.TryGetValue(peerId, out var peer))
                    {
                        peer = new PeerState { PeerId = peerId };
                        _peers[peerId] = peer;
                    }
                    peer.Connection = pc;
                    var name = peerId.Length >= 8 ? peerId[..8] : peerId;
                    AddMessage("System", $"{name} connected", false);
                    StateHasChanged();
                    AttachPendingVideoTracks();
                    PublishTestState();
                    Console.WriteLine($"[ChatRoom] _peers count now {_peers.Count}, peer {name} Connection={(peer.Connection != null ? "set" : "null")}");
                });
            };

            _handler.OnDataChannel += (channel, peerId) =>
            {
                Console.WriteLine($"[ChatRoom] OnDataChannel peerId={peerId[..Math.Min(8, peerId.Length)]} readyState={channel.ReadyState}");
                // Wire message handler on every data channel we receive
                channel.OnStringMessage += msg => InvokeAsync(() =>
                {
                    Console.WriteLine($"[ChatRoom] incoming chat msg from {peerId[..Math.Min(8, peerId.Length)]}: {msg}");
                    var name = peerId.Length >= 8 ? peerId[..8] : peerId;
                    AddMessage(name, msg, false);
                    StateHasChanged();
                    ScrollChat();
                    PublishTestState();
                    // Auto-reply (test harness) - echoes a canned string back on every received message
                    if (!string.IsNullOrEmpty(AutoReply) && channel.ReadyState == "open")
                    {
                        try { channel.Send(AutoReply); } catch { }
                    }
                });

                channel.OnOpen += () => InvokeAsync(() =>
                {
                    Console.WriteLine($"[ChatRoom] DataChannel OPEN peerId={peerId[..Math.Min(8, peerId.Length)]}");
                    var name = peerId.Length >= 8 ? peerId[..8] : peerId;
                    AddMessage("System", $"Chat ready with {name}", false);
                    StateHasChanged();
                    PublishTestState();
                    // Auto-send-after-connect (test harness) - fires once when the first channel opens
                    if (!_autoSent && !string.IsNullOrEmpty(AutoSend))
                    {
                        _autoSent = true;
                        try { channel.Send(AutoSend); AddMessage("You", AutoSend, true); StateHasChanged(); } catch { }
                    }
                });

                // Associate the channel with the peer via the UI-thread context so we share
                // ordering with OnPeerConnection's InvokeAsync. OnPeerConnection and
                // OnDataChannel can fire in either order relative to _peers mutations; create
                // the PeerState if missing so the channel is never dropped.
                InvokeAsync(() =>
                {
                    if (!_peers.TryGetValue(peerId, out var peerState))
                    {
                        peerState = new PeerState { PeerId = peerId };
                        _peers[peerId] = peerState;
                    }
                    peerState.ChatChannel = channel;
                    PublishTestState();
                    Console.WriteLine($"[ChatRoom] stored ChatChannel on peer {peerId[..Math.Min(8, peerId.Length)]} (Connection={(peerState.Connection != null ? "set" : "null")})");
                });
            };

            _handler.OnPeerDisconnected += peerId => InvokeAsync(() =>
            {
                Console.WriteLine($"[ChatRoom] OnPeerDisconnected peerId={peerId[..Math.Min(8, peerId.Length)]}");
                if (_peers.TryGetValue(peerId, out var peer))
                {
                    peer.Dispose();
                    _peers.Remove(peerId);
                }
                var name = peerId.Length >= 8 ? peerId[..8] : peerId;
                AddMessage("System", $"{name} disconnected", false);
                StateHasChanged();
            });

            var localPeerId = new byte[20];
            System.Security.Cryptography.RandomNumberGenerator.Fill(localPeerId);
            _tracker = new TrackerSignalingClient(_trackerUrl, localPeerId);
            Console.WriteLine($"[ChatRoom] localPeerId={Convert.ToHexString(localPeerId)[..8]} tracker={_trackerUrl}");
            if (!string.IsNullOrEmpty(TestId))
            {
                PublishToHarness($"chatRoomTrackerUrl_{TestId}", _trackerUrl);
            }

            _tracker.OnConnected += () => InvokeAsync(() =>
            {
                Console.WriteLine($"[ChatRoom] tracker OnConnected");
                AddMessage("System", $"Connected to tracker. Waiting for peers...", false);
                StateHasChanged();
                if (!string.IsNullOrEmpty(TestId))
                {
                    PublishToHarness($"chatRoomTrackerConnected_{TestId}", DateTime.UtcNow.Ticks);
                }
            });
            _tracker.OnWarning += w =>
            {
                Console.WriteLine($"[ChatRoom] tracker OnWarning: {w}");
                if (!string.IsNullOrEmpty(TestId))
                {
                    PublishToHarness($"chatRoomTrackerWarning_{TestId}", w ?? "");
                }
            };

            _tracker.Subscribe(_roomKey, _handler);
            Console.WriteLine($"[ChatRoom] Subscribed to room, announcing started...");
            await _tracker.AnnounceAsync(_roomKey, new AnnounceOptions { Event = "started", NumWant = 5 });
            Console.WriteLine($"[ChatRoom] Announce complete");
            if (!string.IsNullOrEmpty(TestId))
            {
                PublishToHarness($"chatRoomAnnounced_{TestId}", DateTime.UtcNow.Ticks);
            }
            PublishTestState();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatRoom] JoinRoom EXCEPTION: {ex}");
            AddMessage("Error", ex.Message, false);
            StateHasChanged();
            if (!string.IsNullOrEmpty(TestId))
            {
                PublishToHarness($"chatRoomError_{TestId}", ex.Message);
            }
        }
    }

    private void SendChat()
    {
        if (string.IsNullOrWhiteSpace(_chatInput)) return;

        AddMessage("You", _chatInput, true);

        foreach (var peer in _peers.Values)
        {
            if (peer.ChatChannel?.ReadyState == "open")
            {
                peer.ChatChannel.Send(_chatInput);
            }
        }

        _chatInput = "";
        StateHasChanged();
        ScrollChat();
    }

    private void ToggleMic()
    {
        _micMuted = !_micMuted;
        if (_localStream != null)
        {
            foreach (var track in _localStream.GetAudioTracks())
            {
                track.Enabled = !_micMuted;
            }
        }
    }

    private void ToggleCam()
    {
        _camMuted = !_camMuted;
        if (_localStream != null)
        {
            foreach (var track in _localStream.GetVideoTracks())
            {
                track.Enabled = !_camMuted;
            }
        }
    }

    private async Task LeaveRoom()
    {
        if (_tracker != null)
        {
            try { await _tracker.AnnounceAsync(_roomKey, new AnnounceOptions { Event = "stopped", NumWant = 0 }); }
            catch { /* best effort */ }
            _tracker.Unsubscribe(_roomKey);
            await _tracker.DisposeAsync();
            _tracker = null;
        }
        _handler?.Dispose();
        _handler = null;

        if (_localStream != null)
        {
            foreach (var track in _localStream.GetTracks())
            {
                track.Stop();
                track.Dispose();
            }
            _localStream.Dispose();
            _localStream = null;
        }

        foreach (var peer in _peers.Values) peer.Dispose();
        _peers.Clear();
        _messages.Clear();
        _joined = false;
        StateHasChanged();
    }

    private void AddMessage(string sender, string text, bool isLocal)
    {
        _messages.Add(new ChatMessage { Sender = sender, Text = text, IsLocal = isLocal });
        if (_messages.Count > 200) _messages.RemoveAt(0);
    }

    private async void AttachPendingVideoTracks()
    {
        // Match pending video tracks to peers by their connection reference
        var matched = new List<IRTCPeerConnection>();
        foreach (var kvp in _pendingVideoTracks)
        {
            var pc = kvp.Key;
            var track = kvp.Value;
            var peer = _peers.Values.FirstOrDefault(p => p.Connection == pc);
            if (peer != null)
            {
                matched.Add(pc);
                peer.VideoTrack = track;
                StateHasChanged();
                await Task.Delay(200); // Let Blazor render the video element
                var remoteVideo = new HTMLVideoElement(peer.VideoRef);
                var stream = new MediaStream();
                stream.AddTrack(track);
                remoteVideo.SrcObject = stream;
                peer.RemoteStream = stream;
                peer.RemoteVideoEl = remoteVideo;
            }
        }
        foreach (var pc in matched) _pendingVideoTracks.Remove(pc);
    }

    private void ScrollChat()
    {
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(50);
            using var el = new Element(_chatMessagesRef);
            el.ScrollTop = el.ScrollHeight;
        });
    }

    private static string ComputeInfoHash(string roomName)
        => RoomKey.FromString(roomName.Trim()).ToHex();

    public async ValueTask DisposeAsync()
    {
        if (_tracker != null)
        {
            await _tracker.DisposeAsync();
            _tracker = null;
        }
        _handler?.Dispose();
        _handler = null;
        foreach (var peer in _peers.Values) peer.Dispose();
        _peers.Clear();
        if (_localStream != null)
        {
            foreach (var track in _localStream.GetTracks())
            {
                track.Stop();
                track.Dispose();
            }
            _localStream.Dispose();
        }
    }

    private class PeerState : IDisposable
    {
        public string PeerId { get; set; } = "";
        public IRTCPeerConnection? Connection { get; set; }
        public IRTCDataChannel? ChatChannel { get; set; }
        public ElementReference VideoRef { get; set; }
        public MediaStreamTrack? VideoTrack { get; set; }
        public MediaStream? RemoteStream { get; set; }
        public HTMLVideoElement? RemoteVideoEl { get; set; }

        public void Dispose()
        {
            RemoteVideoEl?.Dispose();
            RemoteStream?.Dispose();
            VideoTrack?.Dispose();
            ChatChannel?.Dispose();
            Connection?.Dispose();
        }
    }

    private class ChatMessage
    {
        public string Sender { get; set; } = "";
        public string Text { get; set; } = "";
        public bool IsLocal { get; set; }
    }
}
