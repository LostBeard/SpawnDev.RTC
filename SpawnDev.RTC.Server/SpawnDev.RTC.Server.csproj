<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>1.0.3</Version>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.RTC.Server</Title>
		<Authors>LostBeard</Authors>
		<Description>WebRTC signaling server for SpawnDev.RTC consumers. Hosts the WebTorrent tracker wire protocol so any ASP.NET Core app can run a room-based signaling endpoint with a single `app.UseRtcSignaling("/announce")` call. Works as a dedicated signaling server for multiplayer games, collaborative tools, voice chat, agent swarms, distributed compute - and simultaneously as a WebTorrent-compatible public tracker.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.RTC</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.RTC.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>WebRTC;Signaling;Tracker;WebTorrent;P2P;Server;AspNetCore;DataChannel;RealTime</PackageTags>
		<PackageReleaseNotes>v1.0.3 stable: Big bundle since 1.0.0. NEW: embedded RFC 5766 STUN/TURN server as an ASP.NET Core IHostedService (`AddRtcStunTurn(...)`). One host box can run WebSocket signaling + STUN binding + TURN relay together. Auth modes: classic long-term credentials, ephemeral/REST-API HMAC credentials (RFC 8489 §9.2 pattern a la Twilio / Cloudflare), period-rotating sub-secrets (master-secret leak only exposes currently-valid periods), tracker-gated ephemeral (only peers with live WebSocket session can allocate relays). NAT port-range support (`RelayPortRangeStart/End`) for home/SMB deployments. Origin-header allowlist (`TrackerServerOptions.AllowedOrigins`, exact + wildcard-subdomain) on the /announce WebSocket endpoint. `TrackerSignalingServer.IsPeerConnected` / `ConnectedPeerIds` / `IsOriginAllowed` exposed for consumer middleware. Tracker now completes WebSocket close-handshake cleanly and catches WebSocketException / ConnectionResetException / IOException so unclean-disconnect stack traces don't fill the fail log. Production-validated at hub.spawndev.com (full 5-step deny -> announce -> allocate -> disconnect -> deny cycle green from external client). 24 integration tests in DesktopTurnAuthTests cover every path end-to-end. See CHANGELOG.md in the repo for per-rc breakdown.</PackageReleaseNotes>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<NoWarn>$(NoWarn);CS1591</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SpawnDev.RTC\SpawnDev.RTC.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Include="..\SpawnDev.RTC\Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
