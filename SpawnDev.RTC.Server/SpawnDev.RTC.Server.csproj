<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>1.0.6</Version>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.RTC.Server</Title>
		<Authors>LostBeard</Authors>
		<Description>WebRTC signaling server for SpawnDev.RTC consumers. Hosts the WebTorrent tracker wire protocol so any ASP.NET Core app can run a room-based signaling endpoint with a single `app.UseRtcSignaling("/announce")` call. Works as a dedicated signaling server for multiplayer games, collaborative tools, voice chat, agent swarms, distributed compute - and simultaneously as a WebTorrent-compatible public tracker.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.RTC</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.RTC.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>WebRTC;Signaling;Tracker;WebTorrent;P2P;Server;AspNetCore;DataChannel;RealTime</PackageTags>
		<PackageReleaseNotes>v1.0.6: align WebSocket-tracker announce response with the JS reference (`webtorrent/bittorrent-tracker` server.js). The C# `TrackerSignalingServer.HandleAnnounceAsync` previously included a `peers` field in the announce response (a list of peer-id summaries); the JS reference does NOT - peer-list semantics are a TCP/UDP-tracker concept, and on the WebRTC path peer discovery happens exclusively via the forwarded offer/answer mechanism. The extra field was a divergence that could desync clients strictly following the JS WebTorrent peer flow. Verified head-to-head against the local `bittorrent-tracker` npm package by `tracker-debug/verify-offer-flow-local.mjs` 2026-04-28. No public API surface change - `AnnounceResponse.Peers` property and `PeerSummary` type are retained for backward-compat, just unused in the response. Forwarded-offer behavior unchanged: announcer's offers still distributed one per existing peer, matching the reference exactly.</PackageReleaseNotes>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<NoWarn>$(NoWarn);CS1591</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SpawnDev.RTC\SpawnDev.RTC.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Include="..\SpawnDev.RTC\Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
