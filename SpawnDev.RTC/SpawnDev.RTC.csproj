<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>1.1.8-rc.1</Version>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.RTC</Title>
		<Authors>LostBeard</Authors>
		<Description>Cross-platform WebRTC for .NET. Browser (Blazor WASM) and desktop from a single API. Data channels, audio, video, media streams, tracks, transceivers, ICE, DTLS, SCTP. Zero-copy JS types in WASM. Serverless signaling via WebTorrent tracker protocol. Powered by SpawnDev.BlazorJS (browser) and SipSorcery (desktop).</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.RTC</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.RTC.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>Blazor;BlazorWebAssembly;WebRTC;CrossPlatform;DataChannel;Video;Audio;MediaStream;ICE;DTLS;SCTP;SipSorcery;WebTorrent;P2P;RealTime</PackageTags>
		<PackageReleaseNotes>v1.1.8-rc.1: Critical desktop SCTP backpressure fix - `DesktopRTCDataChannel.OnBufferedAmountLow` now actually fires. Before this rc, the event was declared on the desktop wrapper but explicitly never raised (the comment said "SipSorcery doesn't have this - never fires"). Consumers that relied on it for spec'd backpressure handling - notably `SpawnDev.WebTorrent.RtcPeer.Send`, which awaits the event when the SCTP send queue exceeds 64 KB - sat on the 30-second `WaitAsync` timeout for every multi-MB push. The TimeoutException propagated through `Peer.OnConnected` -&gt; `Peer.Destroy(err)` -&gt; `Wire.Destroy()` and looked to consumers like a real peer departure, killing the wire mid-transfer. Manifested in `SpawnDev.ILGPU.P2P` as "No healthy peers available for dispatch" / 90s dispatch timeouts on every 1MB+ buffer transfer. Fix: `DesktopRTCDataChannel` now starts a low-overhead background polling task (20 ms tick, gated on a non-zero `BufferedAmountLowThreshold`) that fires `OnBufferedAmountLow` exactly once when `bufferedAmount` transitions from above-threshold to at-or-below-threshold (matches the spec's edge-triggered semantics). Diagnosed 2026-04-29 via `[RtcPeer-DIAG]` logging on `LargeBuffer_1MB_DispatchedOverRealWebRtc_BitExact`: the timeout was firing with `BufferedAmount=0` and `ReadyState=open`, proving the channel had drained and the missing signal was the only thing wrong.</PackageReleaseNotes>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<EnableDefaultCompileItems>true</EnableDefaultCompileItems>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<!-- Suppress missing XML doc warnings for now -->
		<NoWarn>$(NoWarn);CS1591</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.2" />
		<PackageReference Include="SpawnDev.BlazorJS" Version="3.5.6" />
		<PackageReference Include="SpawnDev.BlazorJS.Cryptography" Version="3.2.0" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="SpawnDev.RTC.Server" />
	</ItemGroup>

	<!-- SpawnDev.SIPSorcery is our fork of SIPSorcery (namespace + AssemblyName identical
	     to upstream for drop-in compatibility). Conditional wiring:
	       * In-repo builds where the submodule sibling exists: use ProjectReference for
	         hot-iteration. Transitive deps (BouncyCastle, Concentus, etc.) flow normally.
	       * External / standalone builds: use PackageReference so NuGet resolves the
	         fork package from the feed (local or nuget.org).
	     Standard .NET ecosystem conditional pattern (ASP.NET Core uses it). -->
	<ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\Src\sipsorcery\src\SIPSorcery\SIPSorcery.csproj')">
		<ProjectReference Include="..\Src\sipsorcery\src\SIPSorcery\SIPSorcery.csproj" />
	</ItemGroup>
	<ItemGroup Condition="!Exists('$(MSBuildThisFileDirectory)..\Src\sipsorcery\src\SIPSorcery\SIPSorcery.csproj')">
		<PackageReference Include="SpawnDev.SIPSorcery" Version="10.0.5" />
	</ItemGroup>

	<!-- SpawnDev.MultiMedia supplies cross-platform IAudioTrack / IVideoTrack abstractions
	     that Phase 4 wires into SipSorcery's RTP encoder on desktop. Same conditional pattern
	     as the SIPSorcery fork: sibling-repo ProjectReference when present (dev iteration),
	     otherwise PackageReference from the feed. -->
	<ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\..\..\SpawnDev.MultiMedia\SpawnDev.MultiMedia\SpawnDev.MultiMedia\SpawnDev.MultiMedia.csproj')">
		<ProjectReference Include="..\..\..\SpawnDev.MultiMedia\SpawnDev.MultiMedia\SpawnDev.MultiMedia\SpawnDev.MultiMedia.csproj" />
	</ItemGroup>
	<ItemGroup Condition="!Exists('$(MSBuildThisFileDirectory)..\..\..\SpawnDev.MultiMedia\SpawnDev.MultiMedia\SpawnDev.MultiMedia\SpawnDev.MultiMedia.csproj')">
		<PackageReference Include="SpawnDev.MultiMedia" Version="0.1.0-rc.1" />
	</ItemGroup>

	<ItemGroup>
		<None Include="Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
		<None Include="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<SupportedPlatform Include="browser" />
		<SupportedPlatform Include="windows" />
		<SupportedPlatform Include="linux" />
		<SupportedPlatform Include="macos" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Browser\" />
	  <Folder Include="Desktop\" />
	</ItemGroup>

</Project>
